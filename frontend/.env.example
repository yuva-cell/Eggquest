# Frontend Environment Variables — copy to .env.local for local overrides

# Backend API URL (optional — leave blank to use Vite dev proxy in development)
# For production (e.g. Render), set this to your deployed backend URL:
# VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=https://eggquest.onrender.com/api
